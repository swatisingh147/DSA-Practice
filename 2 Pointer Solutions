Lowest Common Ancestor of a Binary Tree III

class Solution:
    def lowestCommonAncestor(self, p: 'Node', q: 'Node') -> 'Node':
        p1=p
        q1=q
        while p1!=q1:
            p1=q if p1 is None else p1.parent
            q1=p if q1 is None else q1.parent
        return p1

