2486. Append Characters to String to Make Subsequence

class Solution(object):
    def appendCharacters(self, s, t):
        i=0
        j=0
        c=0
        while i<len(s) and j<len(t):
            if t[j]==s[i]:
                i+=1
                j+=1
            else:
                i+=1
        if j<len(t):
            c=len(t)-j
        return c

